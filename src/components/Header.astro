---
import CartBadge from './CartBadge';

const pathname = Astro.url.pathname;
const links = [
  { href: '/', label: 'Inicio' },
  { href: '/tienda', label: 'Tienda' },
  { href: '/carrito', label: 'Carrito' },
];
---

<header class="sticky top-0 z-40 pt-2 sm:pt-3 px-2 sm:px-3 md:px-6">
  <div class="glass-nav mx-auto max-w-6xl rounded-xl sm:rounded-2xl border border-[var(--color-berry)]/10 shadow-[0_8px_30px_rgba(201,75,106,0.06)]">
    <div class="px-3 sm:px-4 md:px-7 min-h-12 sm:min-h-14 md:min-h-[4.25rem] py-2 flex items-center justify-between gap-2 sm:gap-4">
      <a
        href="/"
        class="font-display italic text-[var(--color-cocoa)] tracking-tight leading-tight min-w-0"
      >
        <span class="block text-base xs:text-lg sm:text-xl md:text-[1.65rem] truncate max-w-[9.5rem] xs:max-w-[12rem] sm:max-w-none">
          <span class="sm:hidden">Doña Rosa</span>
          <span class="hidden sm:inline">Delicateses Doña Rosa</span>
        </span>
      </a>

      <nav class="flex items-center shrink-0 gap-0.5" aria-label="Principal">
        {
          links.map((link) => {
            const active =
              link.href === '/'
                ? pathname === '/'
                : pathname.startsWith(link.href);
            const isCart = link.href === '/carrito';
            return (
              <a
                href={link.href}
                class:list={[
                  'nav-link relative px-2.5 sm:px-3 py-1.5 sm:py-2 text-xs sm:text-sm tracking-wide rounded-lg sm:rounded-xl',
                  active
                    ? 'text-[var(--color-berry-deep)] font-semibold bg-[var(--color-mousse)]'
                    : 'text-[var(--color-ink-soft)] hover:text-[var(--color-berry-deep)] hover:bg-[var(--color-sugar)]',
                ]}
              >
                {link.label}
                {isCart && <CartBadge client:load />}
              </a>
            );
          })
        }
      </nav>
    </div>
  </div>
</header>
