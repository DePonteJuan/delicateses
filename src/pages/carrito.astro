---
import BaseLayout from '../layouts/BaseLayout.astro';
import CartPage from '../components/CartPage';
import { getSiteSettings } from '../lib/reader';

const site = await getSiteSettings();
---

<BaseLayout title="Carrito" description="Revisa tu pedido y envíalo por WhatsApp a Delicateses Doña Rosa.">
  <section class="mx-auto max-w-6xl px-4 sm:px-5 md:px-8 py-10 sm:py-14 md:py-20" data-reveal>
    <CartPage
      client:load
      whatsappNumber={site.whatsappNumber}
      paymentNote={site.paymentNote}
      orderGreeting={site.orderGreeting}
    />
  </section>
</BaseLayout>
