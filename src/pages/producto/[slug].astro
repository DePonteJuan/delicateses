---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AddToCartButton from '../../components/AddToCartButton';
import { getAllProducts, getProduct } from '../../lib/reader';
import { categoryLabels } from '../../lib/types';
import { formatPrice } from '../../lib/format';

export async function getStaticPaths() {
  const products = await getAllProducts();
  return products.map((product) => ({
    params: { slug: product.slug },
  }));
}

const { slug } = Astro.params;
const product = slug ? await getProduct(slug) : null;

if (!product) {
  return Astro.redirect('/tienda');
}
---

<BaseLayout title={product.name} description={product.description}>
  <section class="mx-auto max-w-6xl px-4 sm:px-5 md:px-8 py-10 sm:py-12 md:py-20">
    <a
      href="/tienda"
      class="inline-flex text-sm text-[var(--color-ink-soft)] hover:text-[var(--color-berry-deep)] mb-6 sm:mb-8 transition-colors"
    >
      ← Volver a la tienda
    </a>

    <div class="grid lg:grid-cols-2 gap-8 sm:gap-10 lg:gap-16 items-start">
      <div class="media-frame aspect-[4/3]" data-reveal>
        <img
          src={product.image ?? '/images/products/galletas-de-avena.svg'}
          alt={product.name}
          class="w-full h-full object-cover"
        />
      </div>

      <div class="lg:pt-4" data-reveal style="--reveal-delay: 100ms">
        <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-berry)] mb-3 font-semibold">
          {categoryLabels[product.category]}
        </p>
        <h1 class="font-display italic text-[clamp(2rem,7vw,3.25rem)] text-[var(--color-cocoa)] mb-4 leading-tight">
          {product.name}
        </h1>
        <p class="text-xl sm:text-2xl font-semibold text-[var(--color-berry-deep)] mb-5 sm:mb-6">
          {formatPrice(product.price)}
        </p>
        <p class="text-[var(--color-ink-soft)] leading-relaxed mb-7 sm:mb-8 max-w-lg text-sm sm:text-base">
          {product.description}
        </p>

        <div class="flex flex-col xs:flex-row flex-wrap gap-3">
          <AddToCartButton
            client:load
            slug={product.slug}
            name={product.name}
            price={product.price}
            available={product.available}
            className="btn-primary px-7 py-3.5 w-full xs:w-auto"
          />
          <a
            href="/carrito"
            class="btn-ghost px-7 py-3.5 inline-flex items-center justify-center w-full xs:w-auto"
          >
            Ver carrito
          </a>
        </div>

        {
          !product.available && (
            <p class="mt-6 text-[var(--color-berry-deep)]">
              Este producto no está disponible por ahora.
            </p>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>
