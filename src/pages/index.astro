---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getAllProducts } from '../lib/reader';

const products = await getAllProducts();
const featured = products.filter((p) => p.featured && p.available).slice(0, 3);
const showcase = featured.length > 0 ? featured : products.filter((p) => p.available).slice(0, 3);
---

<BaseLayout description="Delicateses Doña Rosa — galletas, tortas y postres artesanales. Arma tu pedido y confírmalo por WhatsApp.">
  <section class="hero-shell" aria-label="Inicio">
    <img
      src="/images/hero-bakery.svg"
      alt=""
      class="hero-media"
      aria-hidden="true"
      fetchpriority="high"
    />
    <div class="hero-veil" aria-hidden="true"></div>
    <div class="hero-blob hero-blob-a" aria-hidden="true"></div>
    <div class="hero-blob hero-blob-b" aria-hidden="true"></div>
    <div class="hero-blob hero-blob-c" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-6xl px-5 sm:px-6 md:px-10 min-h-[inherit] flex items-end sm:items-center pb-16 pt-24 sm:py-20 md:py-24">
      <div class="w-full max-w-xl text-[var(--color-cocoa)]">
        <p class="font-display italic text-[clamp(2.6rem,10vw,4.75rem)] leading-[0.95] tracking-tight mb-4 sm:mb-5 stagger-1">
          Delicateses Doña Rosa
        </p>
        <h1 class="text-base sm:text-lg md:text-xl font-medium mb-3 sm:mb-4 stagger-2 text-[var(--color-berry-deep)]">
          Dulzura artesanal para cada ocasión
        </h1>
        <p class="text-sm sm:text-base text-[var(--color-ink-soft)] mb-7 sm:mb-8 max-w-md stagger-3 leading-relaxed">
          Galletas, tortas y postres hechos en Venezuela. Elige lo que quieres y envía tu pedido directo por WhatsApp.
        </p>
        <div class="flex flex-col xs:flex-row flex-wrap gap-3 stagger-4 w-full sm:w-auto">
          <a
            href="/tienda"
            class="btn-primary inline-flex items-center justify-center px-6 sm:px-7 py-3.5 w-full xs:w-auto"
          >
            Ver tienda
          </a>
          <a
            href="/carrito"
            class="btn-ghost inline-flex items-center justify-center px-6 sm:px-7 py-3.5 w-full xs:w-auto bg-white/50"
          >
            Ir al carrito
          </a>
        </div>
      </div>
    </div>

    <a
      href="#destacados"
      class="scroll-hint absolute bottom-5 left-1/2 -translate-x-1/2 z-10 text-[var(--color-berry-deep)]/70 text-xs tracking-[0.2em] uppercase hidden sm:flex flex-col items-center gap-2 stagger-5"
    >
      Explorar
      <span aria-hidden="true" class="block w-px h-6 bg-[var(--color-berry)]/40"></span>
    </a>
  </section>

  <section id="destacados" class="mx-auto max-w-6xl px-4 sm:px-5 md:px-8 py-14 sm:py-20 md:py-28">
    <div class="max-w-2xl mb-10 sm:mb-12" data-reveal>
      <p class="text-xs uppercase tracking-[0.22em] text-[var(--color-berry)] mb-3 font-semibold">
        Destacados
      </p>
      <h2 class="font-display italic text-[clamp(2rem,6vw,3.25rem)] text-[var(--color-cocoa)] mb-3 sm:mb-4">
        Lo que más piden
      </h2>
      <p class="text-[var(--color-ink-soft)] leading-relaxed text-sm sm:text-base">
        Una selección para empezar. Todo el catálogo está en la tienda.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 sm:gap-x-8 gap-y-10 sm:gap-y-12">
      {
        showcase.map((product, index) => (
          <div data-reveal style={`--reveal-delay: ${index * 90}ms`}>
            <ProductCard product={product} />
          </div>
        ))
      }
    </div>

    <div class="mt-10 sm:mt-14" data-reveal style="--reveal-delay: 120ms">
      <a
        href="/tienda"
        class="inline-flex items-center gap-2 text-[var(--color-berry-deep)] font-semibold underline-offset-4 hover:underline"
      >
        Ver todos los productos
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <section class="mx-2 sm:mx-3 md:mx-6 mb-4 sm:mb-6 rounded-2xl sm:rounded-[1.75rem] bg-[var(--color-mousse)]/70 border border-[var(--color-berry)]/10">
    <div class="mx-auto max-w-6xl px-4 sm:px-5 md:px-8 py-12 sm:py-14 md:py-16 grid md:grid-cols-2 gap-8 md:gap-10 items-center" data-reveal>
      <div>
        <h2 class="font-display italic text-[clamp(1.75rem,5vw,2.5rem)] text-[var(--color-cocoa)] mb-3 sm:mb-4">
          Cómo pedir
        </h2>
        <p class="text-[var(--color-ink-soft)] mb-2 leading-relaxed text-sm sm:text-base">
          Sin cuentas ni pasarelas complicadas. Armas el carrito y nos escribes por WhatsApp.
        </p>
      </div>
      <ol class="space-y-4 sm:space-y-5 text-[var(--color-ink)] text-sm sm:text-base">
        <li class="flex gap-3 sm:gap-4 items-start">
          <span class="font-display italic text-2xl sm:text-3xl text-[var(--color-berry)] leading-none w-7 sm:w-8">1</span>
          <p class="pt-1">Elige galletas, tortas o postres en la tienda.</p>
        </li>
        <li class="flex gap-3 sm:gap-4 items-start">
          <span class="font-display italic text-2xl sm:text-3xl text-[var(--color-berry)] leading-none w-7 sm:w-8">2</span>
          <p class="pt-1">Revisa cantidades y total en tu carrito.</p>
        </li>
        <li class="flex gap-3 sm:gap-4 items-start">
          <span class="font-display italic text-2xl sm:text-3xl text-[var(--color-berry)] leading-none w-7 sm:w-8">3</span>
          <p class="pt-1">Envía el pedido por WhatsApp y coordinamos entrega o retiro.</p>
        </li>
      </ol>
    </div>
  </section>
</BaseLayout>
